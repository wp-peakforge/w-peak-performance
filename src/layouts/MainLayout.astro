---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  schema?: object;
}

const {
  title,
  description = "Tested by humans. Readable by agents. W.Peak Performance — recovery tech, automation gear, and field-tested outdoors equipment.",
  image = "/og-default.jpg",
  schema,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | W.Peak Performance</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OG -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | W.Peak Performance`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonicalURL} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,600;1,6..72,400&display=swap" rel="stylesheet" />

    <!-- Schema.org -->
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <!-- Site schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "W.Peak Performance",
      "url": "https://w-peak.com",
      "description": description,
      "publisher": {
        "@type": "Person",
        "name": "Dalen",
        "url": "https://w-peak.com/about"
      }
    })} />
  </head>

  <body class="min-h-screen bg-[#0a0a0a] text-[#f5f0e8]">
    <!-- Nav -->
    <nav class="border-b border-[#2a2a2a] bg-[#0a0a0a]/95 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="font-serif text-xl font-semibold text-[#f5f0e8] hover:text-[#4ba3d4] transition-colors">
          W.Peak Performance
        </a>
        <div class="flex gap-6 text-sm font-medium text-[#d4cfc4]">
          <a href="/recovery" class="hover:text-[#f5f0e8] transition-colors">Recovery</a>
          <a href="/automation" class="hover:text-[#f5f0e8] transition-colors">Automation</a>
          <a href="/field-ops" class="hover:text-[#f5f0e8] transition-colors">Field Ops</a>
          <a href="/gear-reviews" class="hover:text-[#f5f0e8] transition-colors">All Gear</a>
        </div>
      </div>
    </nav>

    <!-- Page content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-[#2a2a2a] mt-24 py-12 px-4">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
          <div>
            <p class="font-serif text-lg text-[#f5f0e8] mb-2">W.Peak Performance</p>
            <p class="text-sm text-[#d4cfc4] leading-relaxed">
              Tested by humans. Readable by agents. Real gear from real use — recovery tech, automation, and Pacific outdoor life.
            </p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[#d4cfc4] mb-3">Silos</p>
            <ul class="space-y-2 text-sm text-[#d4cfc4]">
              <li><a href="/recovery" class="hover:text-[#f5f0e8]">Recovery &amp; Longevity</a></li>
              <li><a href="/automation" class="hover:text-[#f5f0e8]">Automation &amp; Tech</a></li>
              <li><a href="/field-ops" class="hover:text-[#f5f0e8]">Field Ops &amp; Racing</a></li>
            </ul>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[#d4cfc4] mb-3">Site</p>
            <ul class="space-y-2 text-sm text-[#d4cfc4]">
              <li><a href="/about" class="hover:text-[#f5f0e8]">About</a></li>
              <li><a href="/media-kit" class="hover:text-[#f5f0e8]">Media Kit</a></li>
              <li><a href="/gear-reviews" class="hover:text-[#f5f0e8]">All Reviews</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-[#2a2a2a] pt-6">
          <p class="text-xs text-[#d4cfc4] leading-relaxed">
            <strong class="text-[#f5f0e8]">Affiliate Disclosure:</strong> W.Peak Performance participates in affiliate programs including Amazon Associates, REI, Backcountry, West Marine, and DJI. Purchases made through our links earn a commission at no additional cost to you. All reviews reflect genuine personal use — we buy our own gear.
          </p>
          <p class="text-xs text-[#d4cfc4] mt-3">© {new Date().getFullYear()} W.Peak Performance. Tested in Hawaiʻi.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
