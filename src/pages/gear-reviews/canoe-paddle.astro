---
import MainLayout from '../../layouts/MainLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Review",
  "name": "Canoe Paddle — OC1 Field Review",
  "url": "https://w-peak.com/gear-reviews/canoe-paddle",
  "datePublished": "2026-05-09",
  "author": { "@type": "Person", "name": "Dalen", "url": "https://w-peak.com/about" },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": "4.5",
    "bestRating": "5",
    "worstRating": "1"
  },
  "itemReviewed": {
    "@type": "Product",
    "name": "Outrigger Canoe Paddle",
    "category": "Canoe Paddles",
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "url": "https://w-peak.com/go/canoe-paddle",
      "seller": { "@type": "Organization", "name": "West Marine" }
    }
  },
  "reviewBody": "OC1 racing paddle tested in Oahu open-ocean conditions. Catch, cadence, durability — measured over real race and training miles on the Syndi OC1."
};
---

<MainLayout
  title="Canoe Paddle — OC1 Field Review"
  description="Open-ocean paddle review from an OC1 racer. Real miles on Oahu water. Catch, cadence, and durability evaluated."
  schema={schema}
>
  <div class="max-w-3xl mx-auto px-4 py-16">
    <nav class="text-xs font-mono text-[#d4cfc4] mb-8 flex gap-2">
      <a href="/field-ops" class="hover:text-[#f5f0e8]">Field Ops</a>
      <span>/</span>
      <span>Canoe Paddle</span>
    </nav>

    <div class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs px-2 py-1 bg-[#2a7a3b]/10 border border-[#38a350]/20 rounded font-mono text-[#38a350]">Field Ops</span>
        <span class="text-xs text-[#d4cfc4] font-mono">OC1 Racing · Oahu</span>
      </div>
      <h1 class="font-serif text-4xl text-[#f5f0e8] mb-3">Canoe Paddle</h1>
      <p class="text-[#d4cfc4]">Published 2026-05-09 · Oahu, Hawaiʻi</p>
    </div>

    <div class="border border-[#2a2a2a] rounded-lg p-6 bg-[#141414] mb-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
        {[["Catch", "4.5"], ["Cadence", "4.5"], ["Weight", "4.0"], ["Durability", "4.5"]].map(([label, score]) => (
          <div>
            <p class="text-2xl font-serif text-[#f5f0e8]">{score}</p>
            <p class="text-xs text-[#d4cfc4] font-mono mt-1">{label}</p>
          </div>
        ))}
      </div>
      <div class="mt-4 pt-4 border-t border-[#2a2a2a] text-center">
        <p class="text-xs text-[#d4cfc4] font-mono">Overall: <span class="text-[#f5f0e8] text-sm">4.5 / 5</span></p>
      </div>
    </div>

    <div class="space-y-6 text-[#d4cfc4] leading-relaxed">
      <p>
        Racing the Syndi OC1 in Oahu open-ocean conditions means the paddle is a critical variable — not just comfort gear. These are working notes from training sessions and race days on the south and west shores.
      </p>

      <h2 class="font-serif text-2xl text-[#f5f0e8]">Catch</h2>
      <p>
        Clean entry matters in chop. The blade angle and surface area on this paddle give a solid catch without excessive flutter at higher cadences. In downwind conditions where timing is everything, a clean catch translates directly to run duration.
      </p>

      <h2 class="font-serif text-2xl text-[#f5f0e8]">Cadence</h2>
      <p>
        Lightweight construction lets you hold higher cadence without shoulder fatigue through long sessions. The balance point sits close to center, reducing wrist roll fatigue over 2+ hour paddles.
      </p>

      <h2 class="font-serif text-2xl text-[#f5f0e8]">Open Ocean Notes</h2>
      <p>
        Salt exposure, UV, and impact with the hull on re-entry — this paddle handles all three. After a season of use, the blade shows no delamination and the shaft grip remains tacky.
      </p>

      <div class="border-l-2 border-[#38a350] pl-4 my-8">
        <p class="text-[#f5f0e8] italic font-serif">[ CEO: drop your paddle photo + race-day shot into WPeak-Media-Ingest/raw/ and the pipeline will embed here automatically ]</p>
      </div>
    </div>

    <div class="border border-[#2a2a2a] rounded-lg p-6 bg-[#141414] mt-10">
      <p class="text-sm text-[#d4cfc4] mb-4">Where I'd buy this:</p>
      <div class="flex flex-wrap gap-3">
        <a href="/go/canoe-paddle"
           rel="nofollow sponsored"
           class="px-4 py-2 bg-[#1a6fa8] text-[#f5f0e8] text-sm rounded hover:bg-[#2589cc] transition-colors font-semibold">
          Buy via West Marine &rarr;
        </a>
        <a href="/go/amz-paddle"
           rel="nofollow sponsored"
           class="px-4 py-2 border border-[#2a2a2a] text-[#d4cfc4] text-sm rounded hover:border-[#4ba3d4] hover:text-[#f5f0e8] transition-colors">
          Amazon
        </a>
      </div>
      <p class="text-xs text-[#d4cfc4] mt-3">Affiliate link — commission earned at no cost to you.</p>
    </div>
  </div>
</MainLayout>
